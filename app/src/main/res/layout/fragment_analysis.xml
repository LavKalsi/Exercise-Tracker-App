<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/appBgColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <!-- ── Header ──────────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Performance"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="?attr/appOnSurfaceColor"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Track your progress over time"
            android:textSize="13sp"
            android:textColor="?attr/appOnSurfaceVariantColor"
            android:layout_marginBottom="16dp" />

        <!-- ── Range selector ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_glass_card"
            android:padding="4dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/rangeDay"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Week"
                android:textSize="13sp"
                android:textColor="?attr/colorOnPrimary"
                android:background="@drawable/bg_nav_selected" />

            <TextView
                android:id="@+id/rangeMonth"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text="6 Months"
                android:textSize="13sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:background="@android:color/transparent" />

            <TextView
                android:id="@+id/rangeYear"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text="4 Years"
                android:textSize="13sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <!-- ── Stat cards row ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Total workouts -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:id="@+id/tvSummaryTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Workouts"
                    android:textSize="11sp"
                    android:textColor="?attr/appOnSurfaceVariantColor"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Total reps -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:id="@+id/tvSummaryReps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Reps"
                    android:textSize="11sp"
                    android:textColor="?attr/appOnSurfaceVariantColor"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_glass_panel">

                <TextView
                    android:id="@+id/tvStreak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:text="0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 Streak"
                    android:textSize="11sp"
                    android:textColor="?attr/appOnSurfaceVariantColor"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Second stat row ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_glass_card">

                <TextView
                    android:id="@+id/tvSummaryBest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:gravity="center"
                    android:text="-" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Best Period"
                    android:textSize="11sp"
                    android:textColor="?attr/appOnSurfaceVariantColor"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="14dp"
                android:background="@drawable/bg_glass_card">

                <TextView
                    android:id="@+id/tvSummaryAvg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    android:text="0.0" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Avg / Period"
                    android:textSize="11sp"
                    android:textColor="?attr/appOnSurfaceVariantColor"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Workouts bar chart ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Completed Exercises"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/appOnSurfaceColor"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Number of exercises completed per period"
                android:textSize="11sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:layout_marginBottom="12dp" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChartWorkouts"
                android:layout_width="match_parent"
                android:layout_height="220dp" />

        </LinearLayout>

        <!-- ── Reps bar chart ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Reps"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/appOnSurfaceColor"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total reps logged per period"
                android:textSize="11sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:layout_marginBottom="12dp" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChartReps"
                android:layout_width="match_parent"
                android:layout_height="220dp" />

        </LinearLayout>

        <!-- ── Muscle group pie chart ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Muscle Group Focus"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/appOnSurfaceColor"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Distribution of completed exercises by muscle group"
                android:textSize="11sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:layout_marginBottom="12dp" />

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChartMuscle"
                android:layout_width="match_parent"
                android:layout_height="260dp" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvPieEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No data yet — complete some exercises to see your muscle focus"
                android:textSize="13sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Top exercises ─────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_glass_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Top Exercises"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/appOnSurfaceColor"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Most completed exercises in this period"
                android:textSize="11sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:id="@+id/containerTopExercises"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/tvTopEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No data yet"
                android:textSize="13sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:gravity="center"
                android:padding="16dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- ── Horizontal bar chart — reps per muscle ─────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_glass_panel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reps by Muscle Group"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/appOnSurfaceColor"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total reps logged per muscle group"
                android:textSize="11sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:layout_marginBottom="12dp" />

            <com.github.mikephil.charting.charts.HorizontalBarChart
                android:id="@+id/hBarChartMuscleReps"
                android:layout_width="match_parent"
                android:layout_height="240dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
