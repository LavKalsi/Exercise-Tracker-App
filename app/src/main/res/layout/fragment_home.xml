<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="?attr/appBgColor">

    <!-- Done panel — drop target (top half) -->
    <LinearLayout
        android:id="@+id/panelDone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="10dp"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_glass_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/colorPrimary" />

            <TextView
                android:id="@+id/tvDoneCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:background="@drawable/bg_tag"
                android:text="0" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvDoneEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Drag an exercise here to mark done"
            android:textSize="13sp"
            android:textColor="?attr/appOnSurfaceVariantColor"
            android:gravity="center"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvDone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- To-Do panel (bottom half) — drag source -->
    <LinearLayout
        android:id="@+id/panelTodo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/bg_glass_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To Do"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="?attr/appOnSurfaceVariantColor" />

            <TextView
                android:id="@+id/tvTodoCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="11sp"
                android:textColor="?attr/appOnSurfaceVariantColor"
                android:background="@drawable/bg_tag"
                android:text="0" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTodoEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All done for today!"
            android:textSize="13sp"
            android:textColor="?attr/appOnSurfaceVariantColor"
            android:gravity="center"
            android:visibility="visible" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTodo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipToPadding="false" />

    </LinearLayout>

</LinearLayout>
